# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=digitca

# LDAP автентифікація
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_BIND_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=org
LDAP_USER_ATTR=uid
LDAP_REQUIRED_GROUP=cn=ca-admins,ou=groups,dc=example,dc=org

# CA ключові пасфрази (опційно)
ROOT_CA_KEY_PASSPHRASE=
INTERMEDIATE_CA_KEY_PASSPHRASE=

# REST API сервер
HTTP_BIND=0.0.0.0
HTTP_PORT=8080
# Host порт для docker-compose публікації API (container завжди слухає 8080)
API_PORT=8080

# OCSP responder
OCSP_BIND=0.0.0.0
OCSP_PORT=8082
OCSP_NEXT_UPDATE_SECONDS=3600

# Host порт MongoDB
MONGO_PORT=27017
# Host порт OpenLDAP
LDAP_PORT=389
# Host порт phpLDAPadmin
PHPLDAPADMIN_PORT=8081
# Безпечний дефолт: Basic auth лише через HTTPS.
# Для локального dev без TLS можна тимчасово встановити false.
BASIC_AUTH_REQUIRE_HTTPS=true

# CORS whitelist (через кому). Порожньо = без CORS заголовків.
# Приклад: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# LDAP публікація сертифікатів
# Якщо true — при видачі/відкликанні запис публікується у ou=certificates,<LDAP_BASE_DN>
LDAP_PUBLISH_ENABLED=false

# Рівень логування
RUST_LOG=info
