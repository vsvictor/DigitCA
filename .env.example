# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=digitca

# LDAP автентифікація
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_BIND_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=org
LDAP_USER_ATTR=uid
LDAP_REQUIRED_GROUP=cn=ca-admins,ou=groups,dc=example,dc=org

# CA ключові пасфрази (опційно)
ROOT_CA_KEY_PASSPHRASE=
INTERMEDIATE_CA_KEY_PASSPHRASE=

# REST API сервер
HTTP_BIND=0.0.0.0
HTTP_PORT=8080

# LDAP публікація сертифікатів
# Якщо true — при видачі/відкликанні запис публікується у ou=certificates,<LDAP_BASE_DN>
LDAP_PUBLISH_ENABLED=false

# Рівень логування
RUST_LOG=info
